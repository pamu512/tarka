{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tarka.dev/schemas/tarka-graph-hetero-tenant-schema-v1.json",
  "title": "Tarka graph tenant hetero schema extension (v1)",
  "description": "Optional typed edges and transaction-context hints stored with graph-service GET/PUT /v1/schema/{tenant_id}. Existing tenants without typed_edges keep prior behavior (no extra validation).",
  "type": "object",
  "required": ["schema_id"],
  "additionalProperties": true,
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "tarka.graph_hetero_tenant_schema/v1"
    },
    "typed_edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["relationship", "from_entity_types", "to_entity_types"],
        "properties": {
          "relationship": { "type": "string", "minLength": 1 },
          "from_entity_types": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "to_entity_types": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "node_context_hints": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  }
}
