# Tarka Service Configuration
# Copy this file to .env and customize for your environment

# Database
DATABASE_URL=postgresql+asyncpg://fraud:fraud@localhost:5432/fraud

# Redis
REDIS_URL=redis://localhost:6379/0

# Service URLs (leave empty if not using the service)
FEATURE_SERVICE_URL=
ML_SCORING_URL=
GRAPH_SERVICE_URL=
CALIBRATION_SERVICE_URL=
COUNTER_SERVICE_URL=
LOCATION_SERVICE_URL=

# Auth (development only - leave empty for no auth)
API_KEYS=
ALLOW_INSECURE_NO_AUTH=true
ALLOW_INSECURE_DEV_ROLES=admin,analyst,viewer

# NATS (for event streaming)
NATS_URL=nats://localhost:4222

# OPA (Open Policy Agent)
OPA_URL=

# Tenant binding
TENANT_BINDING_REQUIRED=false
API_KEY_TENANT_MAP=

# LLM provider routing and fallbacks
LLM_PROVIDER=openai
LLM_PROVIDER_FALLBACKS=anthropic,gemini,ollama

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_API_KEY=

GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=

OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b
