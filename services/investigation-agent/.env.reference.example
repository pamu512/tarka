# Saarthi / investigation-agent — reference (minimal integration) profile
# Copy to .env and adjust. Chat + embeddings can point at different OpenAI-compatible bases.

# --- LLM (chat completions) ---
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=qwen2.5:14b-instruct
# COPILOT_CHAT_MODEL=

# Optional: separate embedding server (e.g. Ollama nomic-embed-text on another port)
# COPILOT_EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
# COPILOT_EMBEDDING_API_KEY=ollama
COPILOT_EMBEDDING_MODEL=nomic-embed-text

# Hide tools when case/decision/graph URLs are unset (default true)
COPILOT_HIDE_TOOLS_WITHOUT_UPSTREAM=true

# Reference-first behavior (SOP/wiki; optional plain chat for weak tool-call models)
COPILOT_REFERENCE_MODE=true
# COPILOT_PLAIN_CHAT=false
# COPILOT_PLAIN_PREFETCH_RAG=true

# Upstreams (leave empty for wiki/SOP-only)
# CASE_API_URL=
# DECISION_API_URL=
# GRAPH_SERVICE_URL=

# API_KEYS=
# COPILOT_REQUIRE_INVESTIGATION_API_KEY=false
