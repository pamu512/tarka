# EU / UK–oriented AI governance build (GDPR + EU AI Act–aligned *operational* framing)
# Copy into deploy/.env or inject via your orchestrator.

AI_GOVERNANCE_PROFILE=eu_uk
VITE_AI_GOVERNANCE_PROFILE=eu_uk

# Tighter retention for copilot batch uploads (in-memory)
BATCH_TTL_SECONDS=3600

# Stricter copilot defaults often used with EU/UK deployments
COPILOT_INJECTION_POLICY=reject

# Optional: require API key on investigation-agent
# COPILOT_REQUIRE_INVESTIGATION_API_KEY=true
# API_KEYS=your-service-keys
