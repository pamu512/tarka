# United States–oriented AI governance build (Investigation Copilot + UI)
# Copy into deploy/.env or inject via your orchestrator.

AI_GOVERNANCE_PROFILE=us
VITE_AI_GOVERNANCE_PROFILE=us

# Optional: stricter API access in regulated environments
# COPILOT_REQUIRE_INVESTIGATION_API_KEY=true
# API_KEYS=your-service-keys

# In-memory batch uploads (CSV/JSON/Excel); default 2h unless overridden
# BATCH_TTL_SECONDS=7200
