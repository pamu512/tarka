# Copy to .env next to docker-compose.yml. For `docker compose --profile full up`, enable integrations:
#
# Tiered quick starts (Community vs Pro): docs/docs/guides/deployment-profiles-community-vs-pro.md
# Example fragments: deploy/env/community.env.example, deploy/env/pro-core-cases.env.example, deploy/env/pro-full.env.example
#
# Service URL matrix (compose internal DNS):
#   Ports + OpenAPI file map: docs/docs/guides/service-ports.md
#   Env semantics (localhost): docs/docs/guides/deployment.md
#   core-api:8000 (/decisions, /cases), graph-service:8001, signal-api:8004, integration-ingress:8003,
#   investigation-agent:8006, data-plane:8007, graphql-gateway:8010 — full map: docs/docs/guides/service-ports.md
#   (Slack/Teams/Lark ingress: investigation-agent :8006 /v1/chat/…)
# Case sub-app reads DECISION_API_URL (in core-api this is loopback …/decisions); data-plane uses http://core-api:8000/decisions.
# Data plane ingest: same REDIS_URL as core-api enables POST /v1/events Idempotency-Key deduplication (see ingest-replay-onboarding.md).
# INGEST_ENVELOPE_MODE=optional   # optional | required — v1 envelope { schema_version, event }
# INGEST_REQUIRE_IDEMPOTENCY_KEY=true
# R3.2 — require Idempotency-Key (or idempotency-key) on POST /v1/decisions/evaluate (no server-side dedupe; gateway-friendly)
# TARKA_EVALUATE_REQUIRE_IDEMPOTENCY_KEY=true
# INGEST_DLQ_SUBJECT=fraud.events.dlq
# INGEST_DLQ_PUBLISH_ON_EVALUATE_4XX=false
# TENANT_BINDING_REQUIRED=true
# API_KEY_TENANT_MAP={"service-key":["tenant_a","tenant_b"]}
# Key rotation note: shared auth reads API_KEYS on each request; rotate keys in your secret store and roll pods for non-shared services.
#
# Cloud-managed infrastructure mode:
# - keep service URLs pointed at managed endpoints (RDS/Cloud SQL, ElastiCache/Memorystore, etc.)
# - inject secrets from your secret manager into runtime env (Kubernetes Secret, task secret, or runtime-native secret mounts)
# - do not store resolved secrets in git-tracked files
# See docs/docs/guides/deployment-managed-services.md for contract and examples.

# Decision API — outbound circuit breakers (R2): failures before open, seconds blocked
# CIRCUIT_GRAPH_FAILURE_THRESHOLD=5
# CIRCUIT_GRAPH_RECOVERY_SECONDS=30
# CIRCUIT_FEATURE_FAILURE_THRESHOLD=5
# CIRCUIT_FEATURE_RECOVERY_SECONDS=30
# CIRCUIT_ML_FAILURE_THRESHOLD=5
# CIRCUIT_ML_RECOVERY_SECONDS=30
# CIRCUIT_OPA_FAILURE_THRESHOLD=5
# CIRCUIT_OPA_RECOVERY_SECONDS=30
# CIRCUIT_LIST_FAILURE_THRESHOLD=5
# CIRCUIT_LIST_RECOVERY_SECONDS=30
#
# Per-tenant kill switches (Redis JSON fraud:tenant_flags:{tenant_id}) — PATCH /v1/admin/tenants/{id}/flags
# disable_graph, disable_feature_service, disable_ml, disable_opa, disable_entity_lists (bool)
#
# OSS #31 — optional champion–challenger JSON rule audit (production decision unchanged)
# POLICY_CHAMPION_CHALLENGER_ENABLED=false
# POLICY_COHORT_SALT=policy_v1
#
# N2 — Rule mutations maker–checker: when set, POST/PUT/DELETE on /v1/rules/* requires header
# X-Rule-Governance-Secret with the same value (no-code UI stores token in localStorage).
# RULE_GOVERNANCE_SECRET=
# POLICY_EXPERIMENT_ID=   # optional label stored on audit canary_cohort.experiment_id

FEATURE_SERVICE_URL=http://signal-api:8004/features
ML_SCORING_URL=http://signal-api:8004/ml
# OSS #37 — block activate/traffic-split when metadata fails promotion policy (see services/ml-scoring/rules/ml_promotion_policy_v1.json)
# PROMOTION_GATE_ENFORCE=true
# ML_PROMOTION_OVERRIDE_SECRET=
GRAPH_SERVICE_URL=http://graph-service:8001
CALIBRATION_SERVICE_URL=http://signal-api:8004/calibration
COUNTER_SERVICE_URL=http://signal-api:8004/counters
LOCATION_SERVICE_URL=http://signal-api:8004/location
# Optional override for upstream auth header; defaults to first API_KEYS entry when unset.
# UPSTREAM_API_KEY=
# New first-class upstream circuit breakers (same semantics as existing CIRCUIT_* controls).
# CIRCUIT_CALIBRATION_FAILURE_THRESHOLD=5
# CIRCUIT_CALIBRATION_RECOVERY_SECONDS=30
# CIRCUIT_COUNTER_FAILURE_THRESHOLD=5
# CIRCUIT_COUNTER_RECOVERY_SECONDS=30
# CIRCUIT_LOCATION_FAILURE_THRESHOLD=5
# CIRCUIT_LOCATION_RECOVERY_SECONDS=30
# GRAPH_CHECKPOINT_METADATA_KEY=graph_checkpoint
# DECISION_API_URL=http://core-api:8000/decisions
# OPA_URL=http://opa:8181
# OPENAI_API_KEY=
# ALLOWED_ANALYSTS=alice,bob
# UPSTREAM_API_KEY=   # optional; investigation-agent forwards to case/graph/decision when set
# DECISION_LOG_INCLUDE_PAYLOAD_SNAPSHOT=false

# Regional AI governance (Investigation Copilot): us | eu_uk | global — see deploy/profiles/ai-governance/README.md
# AI_GOVERNANCE_PROFILE=global
# VITE_AI_GOVERNANCE_PROFILE=global
# Optional: when feature-service uses API_KEYS, set the same key for the UI nginx proxy (Feature tools page).
# VITE_FEATURE_SERVICE_API_KEY=
# BATCH_TTL_SECONDS=7200
# COPILOT_INJECTION_POLICY=reject
# COPILOT_TRUSTED_SCOPE_HEADERS_REQUIRED=true

# Integration ingress vault/KMS (optional)
# KMS_PROVIDER=local
# KMS_ACTIVE_KEY_ID=v1
# INTEGRATION_VAULT_KEY=change-me
# KMS_ROTATION_ENABLED=false
# KMS_ROTATION_INTERVAL_SECONDS=86400
# KMS_STARTUP_SELF_CHECK=false
# AWS_KMS_REGION=us-east-1
# AWS_KMS_ENDPOINT_URL=
# GCP_KMS_KEY_RESOURCE=projects/<p>/locations/<l>/keyRings/<r>/cryptoKeys/<k>
# AZURE_KEY_VAULT_URL=https://<vault>.vault.azure.net/
# AZURE_KMS_KEY_NAME=<key-name>
# AZURE_KMS_CREDENTIAL_MODE=default
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
#
# Embedded collaboration chat (chat_bridge) — same process as investigation-agent (host port 8006 by default).
# Operator guide: docs/docs/guides/investigation-collaboration-chat-aws-azure.md
# TEAMS_BRIDGE_SECRET=
# SLACK_SIGNING_SECRET=
# SLACK_BOT_TOKEN=
# BRIDGE_PLUGIN_SECRET=
# LARK_VERIFICATION_TOKEN=
# LARK_TENANT_ACCESS_TOKEN=
# INVESTIGATION_AGENT_URL=http://investigation-agent:8006
# INVESTIGATION_AGENT_API_KEY=
