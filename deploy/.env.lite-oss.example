# Use with docker-compose.lite.yml to enable OSS integrations without the full stack:
#
#   docker compose --env-file .env.lite-oss -f docker-compose.lite.yml --profile core --profile graph --profile ml up -d --build
#
# Wires decision-api to feature-service (velocity / parity), ml-scoring, and graph-service (checkpoints).

FEATURE_SERVICE_URL=http://feature-service:8004
ML_SCORING_URL=http://ml-scoring:8005
GRAPH_SERVICE_URL=http://graph-service:8001
