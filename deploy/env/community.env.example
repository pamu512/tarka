# Community tier — use with: docker compose -f deploy/docker-compose.lite.yml
# Copy to .env beside the compose file or: docker compose --env-file deploy/env/community.env.example ...
#
# Lite compose already sets GRAPH_SERVICE_URL / ML / OPA empty on services.
# Override only if you extend the stack.

# Optional: override DATABASE_URL / REDIS_URL if Postgres or Redis run outside compose.
