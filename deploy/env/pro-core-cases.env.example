# Pro tier — core + graph + cases (no ML, no streaming, no analytics)
# From deploy/: cp env/pro-core-cases.env.example .env && docker compose --profile core --profile graph --profile cases up -d
#
# Adjust hosts if you use host-gateway or external databases.

FEATURE_SERVICE_URL=
ML_SCORING_URL=
GRAPH_SERVICE_URL=http://graph-service:8001
DECISION_API_URL=http://decision-api:8000

# NATS / ClickHouse not used for this slice — leave unset or empty as your services expect
