# Laptop / demo — short Redis velocity windows, shallow graph probes (see packages/tarka-deploy-settings).
TARKA_DEPLOY_PROFILE=demo
REDIS_VELOCITY_TTL=86400
GRAPH_MAX_HOPS=2
# Hetu rule-engine: graph probe budget (ms) + Rust FFI ceiling — explicit vars override Pydantic defaults.
# RULE_ENGINE_GRAPH_FETCH_TIMEOUT_MS=50
# RULE_ENGINE_RUST_FFI_TIMEOUT_MS=150
# Optional: Neo4j heap hint for docker-compose (map to NEO4J_server_memory_heap_max__size).
# NEO4J_JVM_HEAP_MAX_MB=1024
