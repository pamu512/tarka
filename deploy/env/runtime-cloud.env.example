# Throughput / cloud — longer velocity retention in Redis, deeper neighbor expansion for AML-style graph review.
# Neo4j/Janus **entity** history for AML is configured separately (retention months/years), not via Redis TTL.
TARKA_DEPLOY_PROFILE=cloud
REDIS_VELOCITY_TTL=2592000
GRAPH_MAX_HOPS=5
# Cloud: fail-open graph context before checkout SLA; tight Rust FFI deadline (milliseconds).
# RULE_ENGINE_GRAPH_FETCH_TIMEOUT_MS=100
# RULE_ENGINE_RUST_FFI_TIMEOUT_MS=50
# Example heap hints for compose / k8s:
# NEO4J_JVM_HEAP_MAX_MB=8192
# JANUSGRAPH_JVM_HEAP_MAX_MB=4096
# CASSANDRA_JVM_HEAP_MAX_MB=8192
