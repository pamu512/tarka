{
  "name": "Tarka (Nix flake)",
  "build": {
    "context": "..",
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "root",
  "containerEnv": {
    "NIX_CONFIG": "accept-flake-config = true experimental-features = nix-command flakes"
  },
  "forwardPorts": [8000, 8123, 6379, 5432],
  "portsAttributes": {
    "8000": {
      "label": "FastAPI (e.g. Core API / decision stack)",
      "onAutoForward": "notify"
    },
    "8123": {
      "label": "ClickHouse HTTP",
      "onAutoForward": "notify"
    },
    "6379": {
      "label": "Redis",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "notify"
    }
  },
  "postStartCommand": "bash -lc 'if ! pgrep nix-daemon >/dev/null 2>&1; then . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh && nohup nix-daemon >/tmp/nix-daemon.log 2>&1 & fi'",
  "postCreateCommand": "bash -lc 'cd \"${containerWorkspaceFolder}\" && nix develop --accept-flake-config -c true'"
}
