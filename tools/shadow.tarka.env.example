# Shadow local forensic suite — optional add-on (https://github.com/pamu512/shadow)
# Copied to tools/shadow/.env by `python tarka.py forensics` when that file is missing.
#
# Shadow uses its own SQLAlchemy tables (e.g. cases, audit_logs) alongside Tarka's
# investigation_cases / decision_audit in the same database when you point at Tarka Postgres.
#
# Start Tarka Postgres first, e.g.:
#   cd deploy && docker compose --profile core up -d postgres
#
# Defaults match deploy/docker-compose.yml and docker-compose.lite.yml (user/password/db: fraud).

SHADOW_DATABASE_URL=postgresql+asyncpg://fraud:fraud@localhost:5432/fraud
SHADOW_API_PORT=8742
SHADOW_DATA_DIR=.data
SHADOW_WORKSPACE_DIR=workspace
SHADOW_OLLAMA_BASE_URL=http://localhost:11434/v1
SHADOW_OLLAMA_MODEL=llama3.2
# Frontend (browser mode) — must match API port above
VITE_API_BASE=http://127.0.0.1:8742

# Optional: wire Shadow warehouse ingest to a Tarka ETL endpoint when you expose one
# SHADOW_INGESTION_PROVIDER=auto
# SHADOW_TARKA_ETL_BASE_URL=http://127.0.0.1:8000
